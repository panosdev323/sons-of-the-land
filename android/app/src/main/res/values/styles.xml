<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="AppTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:colorBackground">@color/ic_launcher_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- No action bar variant -->
    <style name="AppTheme.NoActionBar" parent="@style/AppTheme">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- Launch/Splash screen style -->
    <style name="AppTheme.NoActionBarLaunch" parent="@style/AppTheme">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowBackground">@color/ic_launcher_background</item>
    </style>
</resources>